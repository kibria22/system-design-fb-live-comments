      "link": null,
      "locked": false,
      "text": "FB Live Comments System Design",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FB Live Comments System Design",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Z3HxpjjVXa1gbXe5-MS4Q",
      "type": "text",
      "x": 396,
      "y": 129.5,
      "width": 354.4597473144531,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 1257543166,
      "version": 151,
      "versionNonce": 1375956030,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784298902058,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- Create Live streaming video post\n- Can see live comments\n- Can see previous comments history\n- Can comment on the post\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- Create Live streaming video post\n- Can see live comments\n- Can see previous comments history\n- Can comment on the post\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "HoPrYXAVH_ScXsd8bHnd8",
      "type": "text",
      "x": 398,
      "y": 292.5,
      "width": 485.35968017578125,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 1086762238,
      "version": 303,
      "versionNonce": 595796478,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784664505906,
      "link": null,
      "locked": false,
      "text": "Non Functional Requirements\n- Millions of live videos per day\n- 1000 comments per video per sec\n- 1 million concurrent watcher per video\n- Availability >> Consistency\n- Low latency for posting comments (500ms)\n- Low latency for receiving live comments (200ms)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non Functional Requirements\n- Millions of live videos per day\n- 1000 comments per video per sec\n- 1 million concurrent watcher per video\n- Availability >> Consistency\n- Low latency for posting comments (500ms)\n- Low latency for receiving live comments (200ms)",
      "autoResize": true,
      "lineHeight": 1.25
    },
