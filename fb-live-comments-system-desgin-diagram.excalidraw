      "boundElements": null,
      "updated": 1784307074151,
      "link": null,
      "locked": false,
      "text": "API Endpoints\n- Post /v1/posts\n- Get /v1/posts?cursor={timestamp}&limit={10}\n- Post /v1/posts/{postId}/comments\n- Get /v1/posts/{postId}/comments?cursor={timestamp}&limit={20}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API Endpoints\n- Post /v1/posts\n- Get /v1/posts?cursor={timestamp}&limit={10}\n- Post /v1/posts/{postId}/comments\n- Get /v1/posts/{postId}/comments?cursor={timestamp}&limit={20}",
      "autoResize": true,
      "lineHeight": 1.25
    },
