    {
      "id": "-NuIAZJCVwf2BC65kbCf3",
      "type": "text",
      "x": -71.90750230173674,
      "y": 1441.3283737145136,
      "width": 636.4195556640625,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aL",
      "roundness": null,
      "seed": 2097967486,
      "version": 635,
      "versionNonce": 1632824958,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784667542136,
      "link": null,
      "locked": false,
      "text": "1. A simple frontend where a page to see all posts\n2. A post create button and a modal\n3. Each tab will have a random userId with random name\nand create the user in db after the tab opens\n4. When the comments button is clicked on a post,\nwe expand the post section bottom with comments\nand we do short polling to get the comments, if we click again\nwe collapse and do not do short polling\n5. Also, we do infinite scrolling to see the earlier comments\nwith cursor based pagination with each page having 20 comments\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. A simple frontend where a page to see all posts\n2. A post create button and a modal\n3. Each tab will have a random userId with random name\nand create the user in db after the tab opens\n4. When the comments button is clicked on a post,\nwe expand the post section bottom with comments\nand we do short polling to get the comments, if we click again\nwe collapse and do not do short polling\n5. Also, we do infinite scrolling to see the earlier comments\nwith cursor based pagination with each page having 20 comments\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
